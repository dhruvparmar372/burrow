---

---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>Burrow — Self-hosted VPN in one command</title>
		<meta name="description" content="Deploy Tailscale exit nodes to AWS, Hetzner Cloud, or Google Cloud. Your cloud, your traffic." />
		<style>
			* { margin: 0; padding: 0; box-sizing: border-box; }
			body { background: #0d1117; color: #e6edf3; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif; }
			code, .mono { font-family: 'SF Mono', 'Fira Code', Menlo, Consolas, monospace; }
			a { color: #2dd4bf; text-decoration: none; }

			:root {
				--accent: #2dd4bf;
				--accent-bg: rgba(45, 212, 191, 0.08);
				--accent-border: rgba(45, 212, 191, 0.25);
				--surface: #161b22;
				--border: #21262d;
				--border-light: #30363d;
				--text-primary: #e6edf3;
				--text-secondary: #8b949e;
				--text-muted: #484f58;
				--bg: #0d1117;
			}

			/* Nav */
			nav { background: rgba(13,17,23,0.8); backdrop-filter: blur(12px); border-bottom: 1px solid var(--border); padding: 16px 48px; display: flex; align-items: center; justify-content: space-between; position: sticky; top: 0; z-index: 100; }
			.nav-logo { display: flex; align-items: center; gap: 10px; font-size: 18px; font-weight: 700; color: #fff; }
			.nav-logo svg { width: 26px; height: 26px; }
			.nav-right { display: flex; align-items: center; gap: 24px; }
			.nav-right a { color: var(--text-secondary); font-size: 14px; }
			.nav-right a:hover { color: #fff; }
			.btn { display: inline-block; padding: 14px 28px; border-radius: 10px; font-size: 15px; font-weight: 600; letter-spacing: 1px; transition: opacity 0.15s; }
			.btn:hover { opacity: 0.9; }
			.btn-accent { background: var(--accent); color: var(--bg) !important; }

			/* Hero */
			.hero { display: flex; flex-direction: column; align-items: center; justify-content: center; max-width: 900px; margin: 0 auto; padding: 0 48px; min-height: calc(100vh - 53px); gap: 40px; text-align: center; }
			.hero-text h1 { font-size: 52px; font-weight: 800; letter-spacing: -1.5px; line-height: 1.08; color: #fff; margin-bottom: 16px; }
			.hero-text p { font-size: 18px; color: var(--text-secondary); line-height: 1.6; margin-bottom: 12px; }
			.hero-prereqs { font-size: 14px; color: var(--text-muted); }
			.hero-prereqs a { color: var(--text-secondary); text-decoration: underline; text-decoration-color: var(--border-light); text-underline-offset: 3px; }
			.hero-prereqs a:hover { color: var(--accent); text-decoration-color: var(--accent); }

			/* Install command */
			.install-cmd { width: 100%; max-width: 700px; }
			.install-cmd label { display: block; font-size: 13px; color: var(--text-muted); margin-bottom: 8px; }
			.install-cmd-box { display: flex; align-items: center; background: var(--surface); border: 1px solid var(--border-light); border-radius: 10px; overflow: hidden; }
			.install-cmd-box code { flex: 1; padding: 14px 16px; font-size: 14px; color: var(--accent); white-space: nowrap; overflow-x: auto; text-align: left; }
			.install-cmd-box button { background: none; border: none; border-left: 1px solid var(--border-light); padding: 14px 16px; cursor: pointer; color: var(--text-muted); font-size: 14px; transition: color 0.15s; flex-shrink: 0; }
			.install-cmd-box button:hover { color: var(--accent); }
			.install-cmd-box button.copied { color: var(--accent); }

			.hero-terminal { width: 100%; max-width: 700px; }

			/* Terminal */
			.terminal { background: var(--surface); border: 1px solid var(--border-light); border-radius: 12px; overflow: hidden; box-shadow: 0 24px 64px rgba(0,0,0,0.5); }
			.terminal-chrome { padding: 10px 14px; background: #1c2129; display: flex; gap: 7px; border-bottom: 1px solid var(--border-light); }
			.dot { width: 11px; height: 11px; border-radius: 50%; }
			.dot-r { background: #f85149; }
			.dot-y { background: #d29922; }
			.dot-g { background: #3fb950; }
			.terminal-body { padding: 20px 24px; font-size: 13.5px; line-height: 2; }
			.c { color: var(--accent); }
			.o { color: var(--text-secondary); }
			.b { color: #58a6ff; }

			/* Footer */
			footer { border-top: 1px solid var(--border); padding: 32px 48px; text-align: center; font-size: 13px; color: var(--text-muted); }
			footer a { color: var(--text-secondary); }

			/* Responsive */
			@media (max-width: 768px) {
				nav { padding: 14px 20px; }
				.hero { padding: 60px 20px; gap: 28px; }
				.hero-text h1 { font-size: 36px; }
				.install-cmd-box code { font-size: 11px; }
				footer { padding: 24px 20px; }
			}
		</style>
	</head>
	<body>
		<nav>
			<div class="nav-logo">
				<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 128 128"><defs><linearGradient id="bg" x1="0%" y1="0%" x2="100%" y2="100%"><stop offset="0%" stop-color="#0d1117"/><stop offset="100%" stop-color="#161b22"/></linearGradient></defs><rect width="128" height="128" rx="28" fill="url(#bg)"/><ellipse cx="64" cy="68" rx="44" ry="40" fill="none" stroke="#2dd4bf" stroke-width="4" stroke-opacity="0.15"/><ellipse cx="64" cy="68" rx="32" ry="29" fill="none" stroke="#2dd4bf" stroke-width="4" stroke-opacity="0.35"/><ellipse cx="64" cy="68" rx="20" ry="18" fill="none" stroke="#2dd4bf" stroke-width="4" stroke-opacity="0.6"/><circle cx="64" cy="68" r="7" fill="#2dd4bf"/><path d="M56 28 L64 38 L72 28" fill="none" stroke="#2dd4bf" stroke-width="4" stroke-linecap="round" stroke-linejoin="round"/></svg>
				Burrow
			</div>
			<div class="nav-right">
				<a href="https://github.com/dhruvparmar372/burrow" class="btn btn-accent">VIEW ON GITHUB</a>
			</div>
		</nav>

		<section class="hero">
			<div class="hero-text">
				<h1>Self-hosted VPN in one command.</h1>
				<p>Deploy Tailscale exit nodes to AWS, Hetzner Cloud, or Google Cloud. Your cloud, your traffic.</p>
				<div class="hero-prereqs">Installs <a href="https://developer.hashicorp.com/terraform/install" target="_blank" rel="noopener">Terraform</a> and <a href="https://tailscale.com" target="_blank" rel="noopener">Tailscale</a> if not already present.</div>
			</div>
			<div class="install-cmd">
				<label>Install</label>
				<div class="install-cmd-box">
					<code id="install-text">curl -fsSL https://raw.githubusercontent.com/dhruvparmar372/burrow/main/install.sh | sh</code>
					<button onclick="copyInstall()" id="copy-btn" title="Copy to clipboard">Copy</button>
				</div>
			</div>
			<div class="hero-terminal">
				<div class="terminal">
					<div class="terminal-chrome">
						<div class="dot dot-r"></div>
						<div class="dot dot-y"></div>
						<div class="dot dot-g"></div>
					</div>
					<div class="terminal-body mono">
						<div><span class="c">$ burrow init</span></div>
						<div><span class="b">&#10003; Configuration saved. You're ready to deploy!</span></div>
						<div style="margin-top:6px"><span class="c">$ burrow add --region us-east-1</span></div>
						<div><span class="o">Deploying exit node in aws/us-east-1...</span></div>
						<div><span class="b">&#10003; Exit node deployed: aws/us-east-1</span></div>
						<div style="margin-top:6px"><span class="c">$ burrow add --provider hetzner --region fsn1</span></div>
						<div><span class="o">Deploying exit node in hetzner/fsn1...</span></div>
						<div><span class="b">&#10003; Exit node deployed: hetzner/fsn1</span></div>
						<div style="margin-top:6px"><span class="c">$ burrow add --provider gcp --region us-central1-a</span></div>
						<div><span class="o">Deploying exit node in gcp/us-central1-a...</span></div>
						<div><span class="b">&#10003; Exit node deployed: gcp/us-central1-a</span></div>
					</div>
				</div>
			</div>
		</section>

		<footer>
			Open source on <a href="https://github.com/dhruvparmar372/burrow">GitHub</a> &middot; Built on <a href="https://tailscale.com" target="_blank" rel="noopener">Tailscale</a> + <a href="https://www.terraform.io" target="_blank" rel="noopener">Terraform</a>
		</footer>

		<script>
			function copyInstall() {
				const text = document.getElementById('install-text').textContent;
				navigator.clipboard.writeText(text);
				const btn = document.getElementById('copy-btn');
				btn.textContent = 'Copied!';
				btn.classList.add('copied');
				setTimeout(() => { btn.textContent = 'Copy'; btn.classList.remove('copied'); }, 2000);
			}
		</script>
	</body>
</html>
