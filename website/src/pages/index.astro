<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>Burrow — Self-hosted VPN in one command</title>
		<meta name="description" content="Deploy Tailscale exit nodes to any AWS region. Your cloud, your traffic." />
		<style>
			* { margin: 0; padding: 0; box-sizing: border-box; }
			body { background: #0d1117; color: #e6edf3; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif; }
			code, .mono { font-family: 'SF Mono', 'Fira Code', Menlo, Consolas, monospace; }
			a { color: #2dd4bf; text-decoration: none; }

			:root {
				--accent: #2dd4bf;
				--accent-bg: rgba(45, 212, 191, 0.08);
				--accent-border: rgba(45, 212, 191, 0.25);
				--surface: #161b22;
				--border: #21262d;
				--border-light: #30363d;
				--text-primary: #e6edf3;
				--text-secondary: #8b949e;
				--text-muted: #484f58;
				--bg: #0d1117;
			}

			/* Nav */
			nav { background: rgba(13,17,23,0.8); backdrop-filter: blur(12px); border-bottom: 1px solid var(--border); padding: 16px 48px; display: flex; align-items: center; justify-content: space-between; position: sticky; top: 0; z-index: 100; }
			.nav-logo { display: flex; align-items: center; gap: 10px; font-size: 18px; font-weight: 700; color: #fff; }
			.nav-logo svg { width: 26px; height: 26px; }
			.nav-right { display: flex; align-items: center; gap: 24px; }
			.nav-right a { color: var(--text-secondary); font-size: 14px; }
			.nav-right a:hover { color: #fff; }
			.btn { display: inline-block; padding: 14px 28px; border-radius: 10px; font-size: 15px; font-weight: 600; letter-spacing: 1px; transition: opacity 0.15s; }
			.btn:hover { opacity: 0.9; }
			.btn-accent { background: var(--accent); color: var(--bg) !important; }
			.btn-outline { background: transparent; border: 1px solid var(--border-light); color: var(--text-secondary) !important; }
			.btn-outline:hover { border-color: var(--text-secondary); color: var(--text-primary) !important; }
			/* Hero */
			.hero { display: flex; align-items: center; gap: 64px; max-width: 1100px; margin: 0 auto; padding: 0 48px; min-height: calc(100vh - 53px); }
			.hero-text { flex: 0 0 380px; }
			.hero-text h1 { font-size: 44px; font-weight: 800; letter-spacing: -1.5px; line-height: 1.08; color: #fff; margin-bottom: 16px; }
			.hero-text p { font-size: 17px; color: var(--text-secondary); line-height: 1.6; margin-bottom: 20px; }
			.hero-prereqs { font-size: 14px; color: var(--text-muted); margin-bottom: 28px; }
			.hero-prereqs a { color: var(--text-secondary); text-decoration: underline; text-decoration-color: var(--border-light); text-underline-offset: 3px; }
			.hero-prereqs a:hover { color: var(--accent); text-decoration-color: var(--accent); }
			.hero-ctas { display: flex; gap: 10px; }
			.hero-terminal { flex: 1; min-width: 0; }

			/* Terminal */
			.terminal { background: var(--surface); border: 1px solid var(--border-light); border-radius: 12px; overflow: hidden; box-shadow: 0 24px 64px rgba(0,0,0,0.5); }
			.terminal-chrome { padding: 10px 14px; background: #1c2129; display: flex; gap: 7px; border-bottom: 1px solid var(--border-light); }
			.dot { width: 11px; height: 11px; border-radius: 50%; }
			.dot-r { background: #f85149; }
			.dot-y { background: #d29922; }
			.dot-g { background: #3fb950; }
			.terminal-body { padding: 20px 24px; font-size: 13.5px; line-height: 2; }
			.c { color: var(--accent); }
			.o { color: var(--text-secondary); }
			.b { color: #58a6ff; }

			/* Modal */
			.modal-overlay { display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.6); backdrop-filter: blur(4px); z-index: 200; align-items: center; justify-content: center; }
			.modal-overlay.open { display: flex; }
			.modal { background: var(--surface); border: 1px solid var(--border-light); border-radius: 16px; padding: 32px; width: 440px; max-width: 90vw; }
			.modal h2 { font-size: 20px; font-weight: 700; color: #fff; margin-bottom: 4px; }
			.modal p { font-size: 14px; color: var(--text-muted); margin-bottom: 24px; }
			.modal-options { display: flex; flex-direction: column; gap: 8px; }
			.modal-option { display: flex; align-items: center; gap: 14px; padding: 14px 16px; border-radius: 10px; border: 1px solid var(--border-light); background: var(--bg); text-decoration: none; color: inherit; transition: border-color 0.15s, background 0.15s; }
			.modal-option:hover { border-color: var(--text-secondary); background: #1c2129; }
			.modal-option.detected { border-color: var(--accent-border); background: var(--accent-bg); }
			.modal-option-icon { font-size: 22px; width: 32px; text-align: center; flex-shrink: 0; }
			.modal-option-text { flex: 1; }
			.modal-option-text strong { font-size: 14px; color: #fff; display: block; }
			.modal-option-text span { font-size: 12px; color: var(--text-muted); }
			.modal-badge { font-size: 11px; color: var(--accent); border: 1px solid var(--accent-border); background: var(--accent-bg); padding: 2px 8px; border-radius: 6px; font-weight: 600; white-space: nowrap; }
			.modal-close { margin-top: 20px; text-align: center; }
			.modal-close button { background: none; border: 1px solid var(--border-light); color: var(--text-secondary); padding: 8px 24px; border-radius: 8px; font-size: 14px; cursor: pointer; transition: border-color 0.15s, color 0.15s; }
			.modal-close button:hover { border-color: var(--text-secondary); color: var(--text-primary); }

			/* Footer */
			footer { border-top: 1px solid var(--border); padding: 32px 48px; text-align: center; font-size: 13px; color: var(--text-muted); }
			footer a { color: var(--text-secondary); }

			/* Responsive */
			@media (max-width: 768px) {
				nav { padding: 14px 20px; }
				.hero { flex-direction: column; padding: 60px 20px; gap: 40px; min-height: calc(100vh - 49px); justify-content: center; }
				.hero-text { flex: none; text-align: center; }
				.hero-text h1 { font-size: 32px; }
				.hero-ctas { justify-content: center; }
				footer { padding: 24px 20px; }
			}
		</style>
	</head>
	<body>
		<nav>
			<div class="nav-logo">
				<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 128 128"><defs><linearGradient id="bg" x1="0%" y1="0%" x2="100%" y2="100%"><stop offset="0%" stop-color="#0d1117"/><stop offset="100%" stop-color="#161b22"/></linearGradient></defs><rect width="128" height="128" rx="28" fill="url(#bg)"/><ellipse cx="64" cy="68" rx="44" ry="40" fill="none" stroke="#2dd4bf" stroke-width="4" stroke-opacity="0.15"/><ellipse cx="64" cy="68" rx="32" ry="29" fill="none" stroke="#2dd4bf" stroke-width="4" stroke-opacity="0.35"/><ellipse cx="64" cy="68" rx="20" ry="18" fill="none" stroke="#2dd4bf" stroke-width="4" stroke-opacity="0.6"/><circle cx="64" cy="68" r="7" fill="#2dd4bf"/><path d="M56 28 L64 38 L72 28" fill="none" stroke="#2dd4bf" stroke-width="4" stroke-linecap="round" stroke-linejoin="round"/></svg>
				Burrow
			</div>
			<div class="nav-right">
				<a href="https://github.com/dhruvparmar372/burrow" class="btn btn-accent">VIEW ON GITHUB</a>
			</div>
		</nav>

		<section class="hero">
			<div class="hero-text">
				<h1>Self-hosted VPN in one command.</h1>
				<p>Deploy Tailscale exit nodes to any AWS region. Your cloud, your traffic.</p>
				<div class="hero-prereqs">Requires <a href="https://developer.hashicorp.com/terraform/install" target="_blank" rel="noopener">Terraform</a> and a <a href="https://tailscale.com" target="_blank" rel="noopener">Tailscale</a> account.</div>
				<div class="hero-ctas">
					<button onclick="document.getElementById('dl-modal').classList.add('open')" class="btn btn-accent" style="border:none;cursor:pointer;">DOWNLOAD</button>
					<a href="https://github.com/dhruvparmar372/burrow" class="btn btn-outline">VIEW ON GITHUB</a>
				</div>
			</div>
			<div class="hero-terminal">
				<div class="terminal">
					<div class="terminal-chrome">
						<div class="dot dot-r"></div>
						<div class="dot dot-y"></div>
						<div class="dot dot-g"></div>
					</div>
					<div class="terminal-body mono">
						<div><span class="c">$ burrow config</span></div>
						<div><span class="b">&#10003; Configuration saved</span></div>
						<div style="margin-top:6px"><span class="c">$ burrow add --region us-east-1</span></div>
						<div><span class="o">Deploying exit node in aws/us-east-1...</span></div>
						<div><span class="b">&#10003; Exit node deployed: aws/us-east-1</span></div>
						<div style="margin-top:6px"><span class="c">$ burrow add --region eu-west-1</span></div>
						<div><span class="o">Deploying exit node in aws/eu-west-1...</span></div>
						<div><span class="b">&#10003; Exit node deployed: aws/eu-west-1</span></div>
					</div>
				</div>
			</div>
		</section>

		<footer>
			Open source on <a href="https://github.com/dhruvparmar372/burrow">GitHub</a> &middot; Built on <a href="https://tailscale.com" target="_blank" rel="noopener">Tailscale</a> + <a href="https://www.terraform.io" target="_blank" rel="noopener">Terraform</a>
		</footer>
	<div class="modal-overlay" id="dl-modal" onclick="if(event.target===this)this.classList.remove('open')">
			<div class="modal">
				<h2>Download Burrow</h2>
				<p>Pick your platform</p>
				<div class="modal-options">
					<a class="modal-option" id="dl-darwin-arm64" href="https://github.com/dhruvparmar372/burrow/releases/latest/download/burrow-darwin-arm64">
						<div class="modal-option-icon">&#xF8FF;</div>
						<div class="modal-option-text">
							<strong>macOS</strong>
							<span>Apple Silicon (ARM64)</span>
						</div>
					</a>
					<a class="modal-option" id="dl-darwin-x64" href="https://github.com/dhruvparmar372/burrow/releases/latest/download/burrow-darwin-x64">
						<div class="modal-option-icon">&#xF8FF;</div>
						<div class="modal-option-text">
							<strong>macOS</strong>
							<span>Intel (x64)</span>
						</div>
					</a>
					<a class="modal-option" id="dl-linux-x64" href="https://github.com/dhruvparmar372/burrow/releases/latest/download/burrow-linux-x64">
						<div class="modal-option-icon">&#x1F427;</div>
						<div class="modal-option-text">
							<strong>Linux</strong>
							<span>x64</span>
						</div>
					</a>
					<a class="modal-option" id="dl-linux-arm64" href="https://github.com/dhruvparmar372/burrow/releases/latest/download/burrow-linux-arm64">
						<div class="modal-option-icon">&#x1F427;</div>
						<div class="modal-option-text">
							<strong>Linux</strong>
							<span>ARM64</span>
						</div>
					</a>
				</div>
				<div class="modal-close">
					<button onclick="document.getElementById('dl-modal').classList.remove('open')">CLOSE</button>
				</div>
			</div>
		</div>

		<script>
			function detectPlatform() {
				const ua = navigator.userAgent.toLowerCase();
				const platform = navigator.platform?.toLowerCase() || '';
				if (ua.includes('mac') || platform.includes('mac')) {
					// Check for Apple Silicon via WebGL renderer or default to ARM
					try {
						const canvas = document.createElement('canvas');
						const gl = canvas.getContext('webgl');
						const ext = gl?.getExtension('WEBGL_debug_renderer_info');
						const renderer = ext ? gl?.getParameter(ext.UNMASKED_RENDERER_WEBGL)?.toLowerCase() || '' : '';
						if (renderer.includes('apple') || renderer.includes('m1') || renderer.includes('m2') || renderer.includes('m3') || renderer.includes('m4')) {
							return 'darwin-arm64';
						}
					} catch {}
					return 'darwin-arm64';
				}
				if (ua.includes('linux')) {
					if (ua.includes('aarch64') || ua.includes('arm64')) return 'linux-arm64';
					return 'linux-x64';
				}
				return null;
			}

			const detected = detectPlatform();
			if (detected) {
				const el = document.getElementById('dl-' + detected);
				if (el) {
					el.classList.add('detected');
					const badge = document.createElement('span');
					badge.className = 'modal-badge';
					badge.textContent = 'DETECTED';
					el.appendChild(badge);
				}
			}
		</script>
	</body>
</html>
